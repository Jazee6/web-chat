{
  "name": "web-chat-server",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "test": "bun test",
    "deploy": "wrangler deploy --minify",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "db:push:d1": "drizzle-kit push && drizzle-kit generate && bunx wrangler d1 migrations apply web-chat",
    "db:generate:do": "drizzle-kit generate --config=./drizzle-room.config.ts",
    "db:generate:auth": "bunx @better-auth/cli@latest generate --output src/lib/schema/auth.ts --yes"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.8.0",
    "@openrouter/ai-sdk-provider": "^3.0.0",
    "ai": "^7",
    "aws4fetch": "^1.0.20",
    "better-auth": "^1.6.22",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.27",
    "hono-party": "^2.1.0",
    "uuid": "^14.0.1",
    "web-chat-share": "workspace:*",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.22.4",
    "wrangler": "^4.105.0"
  }
}
