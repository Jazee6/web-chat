{
  "name": "web-chat-server",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy --minify",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "db:push:d1": "drizzle-kit push && drizzle-kit generate && bunx wrangler d1 migrations apply web-chat",
    "db:generate:do": "drizzle-kit generate --config=./drizzle-room.config.ts",
    "db:generate:auth": "bunx @better-auth/cli@latest generate --output src/lib/schema/auth.ts --yes"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.7.6",
    "aws4fetch": "^1.0.20",
    "better-auth": "^1.6.2",
    "dotenv": "^17.4.1",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.12",
    "hono-party": "^2.0.3",
    "uuid": "^13.0.0",
    "web-chat-share": "workspace:*",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.21.0",
    "wrangler": "^4.81.1"
  }
}
